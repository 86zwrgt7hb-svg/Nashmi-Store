server {
    server_name ns.urdun-tech.com *.urdun-tech.com *.free.urdun-tech.com;
    root /var/www/html/public;
    index index.php index.html index.htm;

    # Security Headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=(self)" always;
    # add_header Content-Security-Policy "default-src 'self' https://*.urdun-tech.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.urdun-tech.com https://www.google.com https://www.gstatic.com https://js.stripe.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://*.urdun-tech.com https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://*.urdun-tech.com https://fonts.gstatic.com https://cdn.jsdelivr.net data:; img-src 'self' data: blob: https: http:; connect-src 'self' https://*.urdun-tech.com https://api.openai.com https://api.resend.com https://*.stripe.com; frame-src https://www.google.com https://js.stripe.com;" always;

    # Static file caching - 30 days
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp|avif)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        add_header Access-Control-Allow-Origin "*" always;
        access_log off;
        try_files $uri =404;
    }

    # Laravel build assets - 1 year cache (hashed filenames)
    location /build/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        add_header Access-Control-Allow-Origin "*" always;
        access_log off;
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php8.4-fpm.sock;
        fastcgi_buffer_size 128k;
        fastcgi_buffers 4 256k;
        fastcgi_busy_buffers_size 256k;
        fastcgi_read_timeout 60;
    }

    # Rate limit login/register
    location ~ ^/(login|register) {
        limit_req zone=login burst=5 nodelay;
        try_files $uri $uri/ /index.php?$query_string;
    }

    # Deny access to hidden files
    location ~ /\.(?!well-known) {
        deny all;
    }

    # Deny access to sensitive files
    location ~* \.(env|log|bak|sql)$ {
        deny all;
    }

    listen 443 ssl http2;
    ssl_certificate /etc/letsencrypt/live/urdun-tech-wildcard/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/urdun-tech-wildcard/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

server {
    listen 80;
    server_name ns.urdun-tech.com *.urdun-tech.com *.free.urdun-tech.com;
    return 301 https://$host$request_uri;
}
